{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ANONA_investor_deck/**",
              "TENET_product_deck/**",
              "animations.jsx",
              "competition_deck/**",
              "dialogue.js",
              "flow/**",
              "flow_ctx/**",
              "lobby_deck/**",
              "scene.jsx",
              "tenet-demo/**",
              "tweaks-panel.jsx",
              "ui_kits/tenet/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Brown|Source Serif 4|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Brown, Source Serif 4, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent-bar",
      "--amber-200",
      "--amber-50",
      "--amber-800",
      "--anona-orange",
      "--bg-1",
      "--bg-2",
      "--bg-amber-soft",
      "--border",
      "--border-strong",
      "--fg-1",
      "--fg-2",
      "--fg-3",
      "--fg-accent",
      "--fg-on-amber",
      "--font-display",
      "--font-mono",
      "--font-sans",
      "--font-serif",
      "--fs-body",
      "--fs-display",
      "--fs-display-l",
      "--fs-display-xl",
      "--fs-h1",
      "--fs-h2",
      "--fs-h3",
      "--fs-h4",
      "--fs-kicker",
      "--fs-meta",
      "--fs-small",
      "--ink",
